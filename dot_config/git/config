# =============================================================================
# Git Configuration - Managed by chezmoi
# =============================================================================

# -----------------------------------------------------------------------------
# User Identity (default - personal)
# -----------------------------------------------------------------------------
[user]
    name = Pierre Romon
    email = pierre.romon@gmail.com
    signingkey = B780FECB8A2B46AF

# -----------------------------------------------------------------------------
# Core Settings
# -----------------------------------------------------------------------------
[core]
    excludesFile = ~/.config/git/ignore
    editor = code --wait
    pager = delta

# -----------------------------------------------------------------------------
# Branching & Merging
# -----------------------------------------------------------------------------
[init]
    defaultBranch = main

[pull]
    rebase = false

[push]
    autoSetupRemote = true

[merge]
    conflictstyle = zdiff3

[diff]
    colorMoved = default

# -----------------------------------------------------------------------------
# Commit Signing (GPG)
# -----------------------------------------------------------------------------
[commit]
    gpgsign = true

[tag]
    gpgsign = true

[gpg]
    format = openpgp

# -----------------------------------------------------------------------------
# Credentials
# -----------------------------------------------------------------------------
[credential]
    helper = manager

# -----------------------------------------------------------------------------
# Git LFS
# -----------------------------------------------------------------------------
[filter "lfs"]
    clean = git-lfs clean -- %f
    process = git-lfs filter-process
    required = true
    smudge = git-lfs smudge -- %f

# -----------------------------------------------------------------------------
# Delta (better diff viewer)
# -----------------------------------------------------------------------------
[delta]
    navigate = true
    side-by-side = true
    line-numbers = true

# -----------------------------------------------------------------------------
# Work Profile Override (SAP repositories)
# -----------------------------------------------------------------------------
[includeIf "gitdir:~/Repositories/sap/"]
    path = ~/.config/git/config-sap